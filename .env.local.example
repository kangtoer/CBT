# Database Configuration (Vercel + Neon)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Instruksi:
# 1. Ganti 'user', 'password', 'host', dan 'dbname' dengan kredensial Neon Anda
# 2. Jika menggunakan connection pooling, gunakan endpoint pool untuk DATABASE_URL
# 3. DIRECT_URL harus direct connection (tanpa pool) untuk migrasi
# 4. Jangan commit file ini ke Git - sudah ada di .gitignore
